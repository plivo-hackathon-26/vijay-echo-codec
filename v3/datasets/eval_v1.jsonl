{"id": "correction_ignored_01", "category": "correction_ignored", "difficulty": "medium", "turns": [{"role": "customer", "text": "I'll take a large pepperoni — actually no, make it mushroom, no pepperoni."}, {"role": "agent", "text": "Sure, one large pepperoni and one large mushroom coming right up.", "tool_calls": [{"name": "place_order", "args": {"items": ["large pepperoni", "large mushroom"]}}]}], "expected_intervene": true, "violation_type": "correction_ignored", "reference_correction": "Got it — one large mushroom pizza, no pepperoni."}
