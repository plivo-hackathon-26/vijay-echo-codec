# Required — Plivo account credentials (REST + Stream)
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=

# Required — your ngrok host (or production hostname) WITHOUT the https:// prefix.
# Plivo will hit this for /voice/answer XML and connect WS to /voice/stream.
PUBLIC_HOST=

# Required — Deepgram nova-3 STT
DEEPGRAM_API_KEY=

# Required — LLM provider for the primary agent + Mirror's scorer.
# Works with vanilla OpenAI (omit OPENAI_API_URL) or Azure OpenAI
# (set OPENAI_API_URL=https://<resource>.openai.azure.com/openai/v1).
OPENAI_API_KEY=
OPENAI_API_URL=
OPENAI_MODEL=gpt-4o-mini

# Required — ElevenLabs TTS (mulaw_8000 output)
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Optional — plivo_mirror tuning
PLIVO_MIRROR_THRESHOLD=0.7
PLIVO_MIRROR_COOLDOWN_S=10
PLIVO_MIRROR_TIMEOUT_S=4.0

# Optional — log level
LOG_LEVEL=INFO
