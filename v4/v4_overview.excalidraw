  },
  {
   "id": "t6030",
   "type": "text",
   "x": 1080,
   "y": 620,
   "width": 445,
   "height": 156.0,
   "angle": 0,
   "strokeColor": "#1d2330",
   "backgroundColor": "transparent",
   "fillStyle": "solid",
   "strokeWidth": 1,
   "strokeStyle": "solid",
   "roughness": 0,
   "opacity": 100,
   "groupIds": [],
   "frameId": null,
   "roundness": null,
   "seed": 6030,
   "version": 1,
   "versionNonce": 42210,
   "isDeleted": false,
   "boundElements": null,
   "updated": 1,
   "link": null,
   "locked": false,
   "text": "PROBLEM\nContext window fills, prompt dilutes \u2014 starts on-\nbrand, ends generic.\n\nEXAMPLE\nTurn 1: crisp & professional -> Turn 20: vague\n\nv4 FIX\nPersona guard: track length+tone, re-inject prompt\nsummary at intervals, escalate past a threshold.",
   "fontSize": 12,
   "fontFamily": 2,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "PROBLEM\nContext window fills, prompt dilutes \u2014 starts on-\nbrand, ends generic.\n\nEXAMPLE\nTurn 1: crisp & professional -> Turn 20: vague\n\nv4 FIX\nPersona guard: track length+tone, re-inject prompt\nsummary at intervals, escalate past a threshold.",
   "lineHeight": 1.3,
   "baseline": 12
  },
