   "updated": 1,
   "link": null,
   "locked": false,
   "text": "3.  WRONG ACTION vs INTENT",
   "fontSize": 15,
   "fontFamily": 2,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "3.  WRONG ACTION vs INTENT",
   "lineHeight": 1.3,
   "baseline": 15
  },
  {
   "id": "t6018",
   "type": "text",
   "x": 1080,
   "y": 292,
   "width": 445,
   "height": 156.0,
   "angle": 0,
   "strokeColor": "#1d2330",
   "backgroundColor": "transparent",
   "fillStyle": "solid",
   "strokeWidth": 1,
   "strokeStyle": "solid",
   "roughness": 0,
   "opacity": 100,
   "groupIds": [],
   "frameId": null,
   "roundness": null,
   "seed": 6018,
   "version": 1,
   "versionNonce": 42126,
   "isDeleted": false,
   "boundElements": null,
   "updated": 1,
   "link": null,
   "locked": false,
   "text": "PROBLEM\nTool fires with the wrong args \u2014 different item,\namount, or account.\n\nEXAMPLE\n\"a large mushroom\" -> place_order([\"pepperoni\"])\n\nv4 FIX\nAction guard: args must match state. Zero-argument\ntools read from state, not the model.",
   "fontSize": 12,
   "fontFamily": 2,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "PROBLEM\nTool fires with the wrong args \u2014 different item,\namount, or account.\n\nEXAMPLE\n\"a large mushroom\" -> place_order([\"pepperoni\"])\n\nv4 FIX\nAction guard: args must match state. Zero-argument\ntools read from state, not the model.",
   "lineHeight": 1.3,
   "baseline": 12
  },
