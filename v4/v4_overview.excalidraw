   "boundElements": null,
   "updated": 1,
   "link": null,
   "locked": false,
   "text": "\"Prompt and pray\" breaks under real callers (a prompt is a suggestion, not a constraint).",
   "fontSize": 15,
   "fontFamily": 2,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "\"Prompt and pray\" breaks under real callers (a prompt is a suggestion, not a constraint).",
   "lineHeight": 1.3,
   "baseline": 15
  },
  {
   "id": "t6005",
   "type": "text",
   "x": 84,
   "y": 134,
   "width": 1432,
   "height": 19.5,
   "angle": 0,
   "strokeColor": "#1971c2",
   "backgroundColor": "transparent",
   "fillStyle": "solid",
   "strokeWidth": 1,
   "strokeStyle": "solid",
   "roughness": 0,
   "opacity": 100,
   "groupIds": [],
