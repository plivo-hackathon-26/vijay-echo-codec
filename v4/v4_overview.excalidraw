   "boundElements": null,
   "updated": 1,
   "link": null,
   "locked": false,
   "text": "1.  FABRICATED FACTS",
   "fontSize": 15,
   "fontFamily": 2,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "1.  FABRICATED FACTS",
   "lineHeight": 1.3,
   "baseline": 15
  },
  {
   "id": "t6010",
   "type": "text",
   "x": 74,
   "y": 292,
   "width": 445,
   "height": 171.60000000000002,
   "angle": 0,
   "strokeColor": "#1d2330",
   "backgroundColor": "transparent",
   "fillStyle": "solid",
   "strokeWidth": 1,
   "strokeStyle": "solid",
   "roughness": 0,
   "opacity": 100,
   "groupIds": [],
   "frameId": null,
   "roundness": null,
   "seed": 6010,
   "version": 1,
   "versionNonce": 42070,
   "isDeleted": false,
   "boundElements": null,
   "updated": 1,
   "link": null,
   "locked": false,
   "text": "PROBLEM\nConfidently states a fact it was never given \u2014 a\nprice, hours, a policy, stock.\n\nEXAMPLE\n\"Open at 11pm?\" -> \"Yes, till midnight\" (invented)\n\nv4 FIX\nGrounded verifier checks every consequential claim\nvs validated state + known facts. No fact -> not\nvoiced.",
   "fontSize": 12,
   "fontFamily": 2,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "PROBLEM\nConfidently states a fact it was never given \u2014 a\nprice, hours, a policy, stock.\n\nEXAMPLE\n\"Open at 11pm?\" -> \"Yes, till midnight\" (invented)\n\nv4 FIX\nGrounded verifier checks every consequential claim\nvs validated state + known facts. No fact -> not\nvoiced.",
   "lineHeight": 1.3,
   "baseline": 12
  },
