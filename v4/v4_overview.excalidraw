   "locked": false,
   "text": "4.  COMPLIANCE / DISCLOSURE GAP",
   "fontSize": 15,
   "fontFamily": 2,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "4.  COMPLIANCE / DISCLOSURE GAP",
   "lineHeight": 1.3,
   "baseline": 15
  },
  {
   "id": "t6022",
   "type": "text",
   "x": 74,
   "y": 620,
   "width": 445,
   "height": 156.0,
   "angle": 0,
   "strokeColor": "#1d2330",
   "backgroundColor": "transparent",
   "fillStyle": "solid",
   "strokeWidth": 1,
   "strokeStyle": "solid",
   "roughness": 0,
   "opacity": 100,
   "groupIds": [],
   "frameId": null,
   "roundness": null,
   "seed": 6022,
   "version": 1,
   "versionNonce": 42154,
   "isDeleted": false,
   "boundElements": null,
   "updated": 1,
   "link": null,
   "locked": false,
   "text": "PROBLEM\nSkips a legally-required disclosure \u2014 recording\nnotice, terms, eligibility.\n\nEXAMPLE\n\"go ahead\" -> \"getting that started\" (no notice)\n\nv4 FIX\nDeterministic REQUIRE blocks any reply missing a\nmandated phrase. Logic in code, not prompt.",
   "fontSize": 12,
   "fontFamily": 2,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "PROBLEM\nSkips a legally-required disclosure \u2014 recording\nnotice, terms, eligibility.\n\nEXAMPLE\n\"go ahead\" -> \"getting that started\" (no notice)\n\nv4 FIX\nDeterministic REQUIRE blocks any reply missing a\nmandated phrase. Logic in code, not prompt.",
   "lineHeight": 1.3,
   "baseline": 12
  },
