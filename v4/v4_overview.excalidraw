   "boundElements": null,
   "updated": 1,
   "link": null,
   "locked": false,
   "text": "2.  UNAUTHORIZED COMMITMENT",
   "fontSize": 15,
   "fontFamily": 2,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "2.  UNAUTHORIZED COMMITMENT",
   "lineHeight": 1.3,
   "baseline": 15
  },
  {
   "id": "t6014",
   "type": "text",
   "x": 577,
   "y": 292,
   "width": 445,
   "height": 156.0,
   "angle": 0,
   "strokeColor": "#1d2330",
   "backgroundColor": "transparent",
   "fillStyle": "solid",
   "strokeWidth": 1,
   "strokeStyle": "solid",
   "roughness": 0,
   "opacity": 100,
   "groupIds": [],
   "frameId": null,
   "roundness": null,
   "seed": 6014,
   "version": 1,
   "versionNonce": 42098,
   "isDeleted": false,
   "boundElements": null,
   "updated": 1,
   "link": null,
   "locked": false,
   "text": "PROBLEM\nPromises what it has no authority to give \u2014 a\nrefund, discount, guarantee.\n\nEXAMPLE\n\"Can I get a refund?\" -> \"Sure, full refund!\"\n\nv4 FIX\nCommitment words flag it; verifier checks policy;\ndeterministic FORBID hard-blocks.",
   "fontSize": 12,
   "fontFamily": 2,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "PROBLEM\nPromises what it has no authority to give \u2014 a\nrefund, discount, guarantee.\n\nEXAMPLE\n\"Can I get a refund?\" -> \"Sure, full refund!\"\n\nv4 FIX\nCommitment words flag it; verifier checks policy;\ndeterministic FORBID hard-blocks.",
   "lineHeight": 1.3,
   "baseline": 12
  },
