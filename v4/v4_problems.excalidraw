   "text": "4.  COMPLIANCE / DISCLOSURE GAPS",
   "fontSize": 19,
   "fontFamily": 2,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "4.  COMPLIANCE / DISCLOSURE GAPS",
   "lineHeight": 1.3,
   "baseline": 19
  },
  {
   "id": "t5022",
   "type": "text",
   "x": 76,
   "y": 684,
   "width": 488,
   "height": 202.8,
   "angle": 0,
   "strokeColor": "#1d2330",
   "backgroundColor": "transparent",
   "fillStyle": "solid",
   "strokeWidth": 1,
   "strokeStyle": "solid",
   "roughness": 0,
   "opacity": 100,
   "groupIds": [],
   "frameId": null,
   "roundness": null,
   "seed": 5022,
   "version": 1,
   "versionNonce": 35154,
   "isDeleted": false,
   "boundElements": null,
   "updated": 1,
   "link": null,
   "locked": false,
   "text": "PROBLEM\nA legally-required disclosure is skipped \u2014 recording\nnotice, terms, eligibility.\n\nEXAMPLE\nCaller: \"go ahead\"  \u2192  Agent: \"Great, getting that\nstarted.\" (no recording notice)\n\nHOW v4 STOPS IT\nDeterministic REQUIRE rule blocks any reply that\nomits a mandated phrase. Business rules live in\ncode, not the prompt.",
   "fontSize": 13,
   "fontFamily": 2,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "PROBLEM\nA legally-required disclosure is skipped \u2014 recording\nnotice, terms, eligibility.\n\nEXAMPLE\nCaller: \"go ahead\"  \u2192  Agent: \"Great, getting that\nstarted.\" (no recording notice)\n\nHOW v4 STOPS IT\nDeterministic REQUIRE rule blocks any reply that\nomits a mandated phrase. Business rules live in\ncode, not the prompt.",
   "lineHeight": 1.3,
   "baseline": 13
  },
