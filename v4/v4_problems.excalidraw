   "link": null,
   "locked": false,
   "text": "3.  WRONG ACTION vs INTENT",
   "fontSize": 19,
   "fontFamily": 2,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "3.  WRONG ACTION vs INTENT",
   "lineHeight": 1.3,
   "baseline": 19
  },
  {
   "id": "t5018",
   "type": "text",
   "x": 1172,
   "y": 302,
   "width": 488,
   "height": 202.8,
   "angle": 0,
   "strokeColor": "#1d2330",
   "backgroundColor": "transparent",
   "fillStyle": "solid",
   "strokeWidth": 1,
   "strokeStyle": "solid",
   "roughness": 0,
   "opacity": 100,
   "groupIds": [],
   "frameId": null,
   "roundness": null,
   "seed": 5018,
   "version": 1,
   "versionNonce": 35126,
   "isDeleted": false,
   "boundElements": null,
   "updated": 1,
   "link": null,
   "locked": false,
   "text": "PROBLEM\nThe tool fires with the wrong arguments \u2014 a\ndifferent item, amount, or account than asked for.\n\nEXAMPLE\nCaller: \"a large mushroom\"  \u2192\nplace_order(items=[\"pepperoni\"])\n\nHOW v4 STOPS IT\nAction guard: tool args must match validated state.\nZero-argument tools read values from state, never\nfrom the model.",
   "fontSize": 13,
   "fontFamily": 2,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "PROBLEM\nThe tool fires with the wrong arguments \u2014 a\ndifferent item, amount, or account than asked for.\n\nEXAMPLE\nCaller: \"a large mushroom\"  \u2192\nplace_order(items=[\"pepperoni\"])\n\nHOW v4 STOPS IT\nAction guard: tool args must match validated state.\nZero-argument tools read values from state, never\nfrom the model.",
   "lineHeight": 1.3,
   "baseline": 13
  },
