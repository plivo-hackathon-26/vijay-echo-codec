   "boundElements": null,
   "updated": 1,
   "link": null,
   "locked": false,
   "text": "\"Prompt and pray\" breaks under real callers \u2014 a prompt is a suggestion, not a constraint.",
   "fontSize": 16,
   "fontFamily": 2,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "\"Prompt and pray\" breaks under real callers \u2014 a prompt is a suggestion, not a constraint.",
   "lineHeight": 1.3,
   "baseline": 16
  },
  {
   "id": "t5005",
   "type": "text",
   "x": 84,
   "y": 140,
   "width": 1556,
   "height": 19.5,
   "angle": 0,
   "strokeColor": "#1971c2",
   "backgroundColor": "transparent",
   "fillStyle": "solid",
   "strokeWidth": 1,
   "strokeStyle": "solid",
   "roughness": 0,
   "opacity": 100,
   "groupIds": [],
   "frameId": null,
   "roundness": null,
   "seed": 5005,
   "version": 1,
   "versionNonce": 35035,
   "isDeleted": false,
   "boundElements": null,
   "updated": 1,
   "link": null,
   "locked": false,
   "text": "plivo-mirror v4 is a real-time FIREWALL: it stops each failure BEFORE it reaches the caller or fires a tool \u2014",
   "fontSize": 15,
   "fontFamily": 2,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "plivo-mirror v4 is a real-time FIREWALL: it stops each failure BEFORE it reaches the caller or fires a tool \u2014",
   "lineHeight": 1.3,
   "baseline": 15
  },
  {
   "id": "t5006",
   "type": "text",
   "x": 84,
   "y": 164,
   "width": 1556,
   "height": 19.5,
   "angle": 0,
   "strokeColor": "#1971c2",
