   "updated": 1,
   "link": null,
   "locked": false,
   "text": "2.  UNAUTHORIZED COMMITMENTS",
   "fontSize": 19,
   "fontFamily": 2,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "2.  UNAUTHORIZED COMMITMENTS",
   "lineHeight": 1.3,
   "baseline": 19
  },
  {
   "id": "t5014",
   "type": "text",
   "x": 624,
   "y": 302,
   "width": 488,
   "height": 202.8,
   "angle": 0,
   "strokeColor": "#1d2330",
   "backgroundColor": "transparent",
   "fillStyle": "solid",
   "strokeWidth": 1,
   "strokeStyle": "solid",
   "roughness": 0,
   "opacity": 100,
   "groupIds": [],
   "frameId": null,
   "roundness": null,
   "seed": 5014,
   "version": 1,
   "versionNonce": 35098,
   "isDeleted": false,
   "boundElements": null,
   "updated": 1,
   "link": null,
   "locked": false,
   "text": "PROBLEM\nThe agent promises something it has no authority to\ngive \u2014 a refund, discount, or guarantee.\n\nEXAMPLE\nCaller: \"Can I get a refund?\"  \u2192  Agent: \"Sure, full\nrefund!\"\n\nHOW v4 STOPS IT\nCommitment words flag the span; the verifier checks\nit against policy; a deterministic FORBID rule hard-\nblocks.",
   "fontSize": 13,
   "fontFamily": 2,
   "textAlign": "left",
   "verticalAlign": "top",
   "containerId": null,
   "originalText": "PROBLEM\nThe agent promises something it has no authority to\ngive \u2014 a refund, discount, or guarantee.\n\nEXAMPLE\nCaller: \"Can I get a refund?\"  \u2192  Agent: \"Sure, full\nrefund!\"\n\nHOW v4 STOPS IT\nCommitment words flag the span; the verifier checks\nit against policy; a deterministic FORBID rule hard-\nblocks.",
   "lineHeight": 1.3,
   "baseline": 13
  },
