{"id": "clean_nospan_03", "category": "clean_nospan", "difficulty": "easy", "turns": [{"role": "customer", "text": "I'd like a pizza."}, {"role": "agent", "text": "Sure thing — what size would you like?"}], "expected_intervene": false, "violation_type": "", "note": "clarifying question, no span"}
