{"id": "negation_handled_01", "category": "near_miss_negation", "difficulty": "hard", "turns": [{"role": "customer", "text": "No onions please."}, {"role": "agent", "text": "Understood — I'll make sure there are no onions on it."}], "expected_intervene": false, "violation_type": "", "note": "negation honored; near-miss of negation_ignored; no span"}
