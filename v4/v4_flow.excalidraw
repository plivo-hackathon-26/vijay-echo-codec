   "updated": 1,
   "link": null,
   "locked": false,
   "text": "SPECULATIVE  (opt-in: no-tool +\nlexically-clean turn)\nvoice the reply NOW \u2192 run NLI +\nverifier OFF the first-audio path \u2192\nemit a correction only if it fires.\n~0ms perceived latency.\nTRADEOFF: corrected-AFTER, not\nprevented, on those turns.\nTool calls / numbers / commitments\nstay SYNCHRONOUS.",
   "fontSize": 10,
   "fontFamily": 1,
   "textAlign": "center",
   "verticalAlign": "middle",
   "containerId": "r1071",
   "originalText": "SPECULATIVE  (opt-in: no-tool +\nlexically-clean turn)\nvoice the reply NOW \u2192 run NLI +\nverifier OFF the first-audio path \u2192\nemit a correction only if it fires.\n~0ms perceived latency.\nTRADEOFF: corrected-AFTER, not\nprevented, on those turns.\nTool calls / numbers / commitments\nstay SYNCHRONOUS.",
   "lineHeight": 1.25,
   "baseline": 10
  },
